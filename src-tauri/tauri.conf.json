{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "confluox",
  "version": "0.1.0",
  "identifier": "com.confluox.desktop",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "confluox",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../dist/gateway/confluox-gateway": "gateway"
    }
  }
}
